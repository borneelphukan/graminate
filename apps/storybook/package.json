{
  "name": "@graminate/storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "storybook dev --ci -p 6006",
    "dev:storybook": "storybook dev -p 6006",
    "build": "echo 0",
    "lint": "pnpm eslint",
    "lint:fix": "pnpm eslint --fix",
    "format": "prettier --write .",
    "format:files": "prettier --write",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@graminate/ui": "workspace:*",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-links": "^9.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^9.0.8",
    "@tailwindcss/vite": "^4.1.12",
    "fast-glob": "^3.3.3",
    "storybook": "^9.0.8",
    "tailwindcss": "^4.1.12"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "npm run lint:fix --"
    ],
    "**/*.{json,md,yml,yaml}": [
      "npm run format:files -- --"
    ]
  }
}