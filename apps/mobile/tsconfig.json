{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@graminate/ui": [
        "../../packages/ui/lib/index.ts"
      ],
      "@graminate/ui/*": [
        "../../packages/ui/lib/*"
      ],
      "react-native-paper": [
        "./components/ui/nativewind-ui/index.tsx"
      ],
      "react-native-paper/*": [
        "./components/ui/nativewind-ui/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
