generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
}

model admin {
  admin_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name String    @db.VarChar(100)
  last_name  String    @db.VarChar(100)
  email      String    @unique @db.VarChar(255)
  password   String
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model apiculture {
  apiary_id      Int         @id @default(autoincrement())
  user_id        Int
  apiary_name    String      @db.VarChar(100)
  created_at     DateTime?   @default(now()) @db.Timestamp(6)
  area           Float?
  address_line_1 String?     @db.VarChar(255)
  address_line_2 String?     @db.VarChar(255)
  city           String?     @db.VarChar(100)
  state          String?     @db.VarChar(100)
  postal_code    String?     @db.VarChar(20)
  users          users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
  bee_hives      bee_hives[]
}

model bee_hives {
  hive_id            Int                @id @default(autoincrement())
  apiary_id          Int
  hive_name          String             @db.VarChar(100)
  hive_type          String?            @db.VarChar(50)
  installation_date  DateTime?          @db.Date
  ventilation_status String?            @db.VarChar(50)
  notes              String?
  bee_species        String?            @db.VarChar(100)
  honey_capacity     Float?
  unit               String?            @db.VarChar(20)
  apiculture         apiculture         @relation(fields: [apiary_id], references: [apiary_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_apiary")
  hive_inspection    hive_inspection[]
  honey_production   honey_production[]
}

model cattle_milk {
  milk_id        Int            @id @default(autoincrement())
  cattle_id      Int
  user_id        Int
  date_collected DateTime       @db.Date
  animal_name    String?
  milk_produced  Decimal        @db.Decimal(10, 2)
  date_logged    DateTime?      @default(now()) @db.Timestamp(6)
  cattle_rearing cattle_rearing @relation(fields: [cattle_id], references: [cattle_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cattle_rearing_milk")
  users          users          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_milk")
}

model cattle_rearing {
  cattle_id         Int           @id @default(autoincrement())
  user_id           Int
  cattle_name       String
  cattle_type       String
  number_of_animals Int
  purpose           String?
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  cattle_milk       cattle_milk[]
  users             users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}

model companies {
  company_id     Int       @id @default(autoincrement())
  user_id        Int?
  company_name   String    @db.VarChar(100)
  contact_person String?   @db.VarChar(50)
  email          String?   @db.VarChar(100)
  phone_number   String?   @db.VarChar(15)
  type           String?   @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  address_line_1 String    @db.VarChar(255)
  address_line_2 String?   @db.VarChar(255)
  city           String    @db.VarChar(100)
  state          String    @db.VarChar(100)
  postal_code    String    @db.VarChar(10)
  website        String?   @db.VarChar(255)
  industry       String?   @db.VarChar(50)
  users          users?    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contacts {
  contact_id     Int       @id @default(autoincrement())
  user_id        Int?
  first_name     String    @db.VarChar(50)
  last_name      String?   @db.VarChar(50)
  email          String?   @db.VarChar(100)
  phone_number   String?   @db.VarChar(16)
  type           String?   @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  address_line_1 String?   @db.VarChar(255)
  address_line_2 String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  postal_code    String?   @db.VarChar(10)
  users          users?    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model deals {
  deal_id    Int      @id @default(autoincrement())
  user_id    Int?
  deal_name  String   @db.VarChar(100)
  partner    String   @db.VarChar(50)
  amount     Decimal  @db.Decimal(10, 2)
  stage      String   @db.VarChar(50)
  end_date   DateTime @db.Date
  start_date DateTime @db.Date
  category   String?  @db.VarChar(100)
  priority   String   @default("Medium") @db.VarChar(20)
  users      users?   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model expenses {
  expense_id   Int       @id @default(autoincrement())
  user_id      Int
  title        String    @db.VarChar(255)
  occupation   String?   @db.VarChar(100)
  category     String    @db.VarChar(100)
  expense      Decimal   @db.Decimal(10, 2)
  date_created DateTime  @db.Date
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_expenses")

  @@index([date_created], map: "idx_expenses_date_created")
  @@index([user_id], map: "idx_expenses_user_id")
}

model hive_inspection {
  inspection_id          Int       @id @default(autoincrement())
  hive_id                Int
  inspection_date        DateTime  @db.Date
  queen_status           String?   @db.VarChar(30)
  queen_introduced_date  DateTime? @db.Date
  brood_pattern          String?   @db.VarChar(30)
  notes                  String?
  symptoms               String[]
  population_strength    String?   @db.VarChar(30)
  frames_of_brood        Int?
  frames_of_nectar_honey Int?
  frames_of_pollen       Int?
  room_to_lay            String?   @db.VarChar(30)
  queen_cells_observed   String?   @db.VarChar(5)
  queen_cells_count      Int?
  varroa_mite_method     String?   @db.VarChar(50)
  varroa_mite_count      Int?
  actions_taken          String?
  bee_hives              bee_hives @relation(fields: [hive_id], references: [hive_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_hive")

  @@index([hive_id], map: "idx_hive_inspection_hive_id")
}

model honey_production {
  harvest_id       Int       @id @default(autoincrement())
  hive_id          Int
  harvest_date     DateTime  @db.Date
  honey_weight     Float
  frames_harvested Int?
  honey_type       String?   @db.VarChar(100)
  harvest_notes    String?
  logged_at        DateTime? @default(now()) @db.Timestamp(6)
  bee_hives        bee_hives @relation(fields: [hive_id], references: [hive_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_hive")

  @@index([hive_id], map: "idx_honey_production_hive_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory {
  inventory_id   Int        @id @default(autoincrement())
  user_id        Int?
  item_name      String     @db.VarChar(100)
  item_group     String     @db.VarChar(100)
  units          String     @db.VarChar(50)
  quantity       Int
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  price_per_unit Decimal    @db.Decimal(10, 2)
  warehouse_id   Int?
  minimum_limit  Int?
  feed           Boolean    @default(false)
  users          users?     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  warehouse      warehouse? @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([item_group], map: "idx_inventory_item_group")
  @@index([user_id], map: "idx_inventory_user_id")
}

model invoice_items {
  item_id     Int      @id @default(autoincrement())
  invoice_id  Int
  description String?
  quantity    Decimal  @default(1) @db.Decimal
  rate        Decimal  @default(0) @db.Decimal(10, 2)
  invoices    invoices @relation(fields: [invoice_id], references: [invoice_id], onDelete: Cascade, onUpdate: NoAction)
}

model invoices {
  invoice_id            Int             @id @default(autoincrement())
  user_id               Int?
  title                 String          @db.VarChar(100)
  bill_to               String          @db.VarChar(100)
  due_date              DateTime        @db.Date
  receipt_date          DateTime?       @default(now()) @db.Timestamp(6)
  payment_terms         String?         @db.VarChar(100)
  notes                 String?
  tax                   Decimal?        @default(0) @db.Decimal(10, 2)
  discount              Decimal?        @default(0) @db.Decimal(10, 2)
  shipping              Decimal?        @default(0) @db.Decimal(10, 2)
  receipt_number        String?         @unique @db.VarChar(50)
  issued_date           DateTime?       @default(dbgenerated("CURRENT_DATE")) @db.Date
  bill_to_address_line1 String?         @db.VarChar(255)
  bill_to_address_line2 String?         @db.VarChar(255)
  bill_to_city          String?         @db.VarChar(100)
  bill_to_state         String?         @db.VarChar(100)
  bill_to_postal_code   String?         @db.VarChar(20)
  bill_to_country       String?         @db.VarChar(100)
  sales_id              Int?            @unique(map: "invoices_sales_id_unique")
  invoice_items         invoice_items[]
  sales                 sales?          @relation(fields: [sales_id], references: [sales_id], onUpdate: NoAction)
  users                 users?          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model job_applications {
  id         Int       @id @default(autoincrement())
  job_id     Int
  first_name String    @db.VarChar(100)
  last_name  String    @db.VarChar(100)
  email      String    @unique @db.VarChar(255)
  phone      String    @db.VarChar(15)
  portfolio  String?   @db.VarChar(255)
  cv_file    String
  applied_at DateTime? @default(now()) @db.Timestamp(6)
  jobs       jobs      @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model jobs {
  id               Int                @id @default(autoincrement())
  position         String             @db.VarChar(255)
  type             String             @db.VarChar(50)
  mode             String             @db.VarChar(50)
  description      String
  tasks            String[]
  requirements     String[]
  benefits         String[]
  job_applications job_applications[]
}

model labour_payments {
  payment_id        Int       @id @default(autoincrement())
  labour_id         Int
  payment_date      DateTime  @db.Date
  salary_paid       Decimal   @db.Decimal(10, 2)
  bonus             Decimal   @db.Decimal(10, 2)
  overtime_pay      Decimal   @db.Decimal(10, 2)
  housing_allowance Decimal   @db.Decimal(10, 2)
  travel_allowance  Decimal   @db.Decimal(10, 2)
  meal_allowance    Decimal   @db.Decimal(10, 2)
  total_amount      Decimal   @db.Decimal(10, 2)
  payment_status    String?   @default("Pending") @db.VarChar(20)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  labours           labours   @relation(fields: [labour_id], references: [labour_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model labours {
  labour_id              Int               @id @default(autoincrement())
  user_id                Int?
  full_name              String            @db.VarChar(100)
  date_of_birth          DateTime          @db.Date
  gender                 String            @db.VarChar(10)
  contact_number         String            @db.VarChar(15)
  aadhar_card_number     String            @unique @db.VarChar(12)
  ration_card            String?           @unique @db.VarChar(20)
  pan_card               String?           @unique @db.VarChar(10)
  driving_license        String?           @unique @db.VarChar(20)
  mnrega_job_card_number String?           @unique @db.VarChar(20)
  bank_account_number    String?           @db.VarChar(20)
  ifsc_code              String?           @db.VarChar(11)
  bank_name              String?           @db.VarChar(100)
  bank_branch            String?           @db.VarChar(100)
  disability_status      Boolean?          @default(false)
  epfo                   String?           @unique @db.VarChar(20)
  esic                   String?           @unique @db.VarChar(20)
  pm_kisan               Boolean?          @default(false)
  created_at             DateTime?         @default(now()) @db.Timestamp(6)
  role                   String            @default("Worker") @db.VarChar(50)
  base_salary            Decimal           @default(0.00) @db.Decimal(10, 2)
  bonus                  Decimal?          @db.Decimal(10, 2)
  overtime_pay           Decimal?          @db.Decimal(10, 2)
  housing_allowance      Decimal?          @db.Decimal(10, 2)
  travel_allowance       Decimal?          @db.Decimal(10, 2)
  meal_allowance         Decimal?          @db.Decimal(10, 2)
  payment_frequency      String?           @default("Monthly") @db.VarChar(20)
  address_line_1         String?           @db.VarChar(255)
  address_line_2         String?           @db.VarChar(255)
  city                   String?           @db.VarChar(100)
  state                  String?           @db.VarChar(100)
  postal_code            String?           @db.VarChar(20)
  labour_payments        labour_payments[]
  users                  users?            @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([aadhar_card_number], map: "idx_labour_aadhar")
}

model login_history {
  login_id      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       Int
  logged_in_at  DateTime? @default(now()) @db.Timestamp(6)
  logged_out_at DateTime? @db.Timestamp(6)
  users         users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([user_id], map: "idx_login_history_user_id")
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String @db.VarChar(255)
  batch     Int
}

model password_resets {
  email      String   @id @db.VarChar(100)
  token      String   @db.VarChar(255)
  expires_at DateTime @db.Timestamp(6)
  users      users    @relation(fields: [email], references: [email], onDelete: NoAction, onUpdate: NoAction)
}

model payments {
  payment_id          Int            @id @default(autoincrement())
  user_id             Int
  razorpay_order_id   String         @db.VarChar(255)
  razorpay_payment_id String?        @db.VarChar(255)
  razorpay_signature  String?        @db.VarChar(255)
  amount              Int
  currency            String         @db.VarChar(10)
  status              payment_status @default(PENDING)
  created_at          DateTime?      @default(now()) @db.Timestamp(6)
  updated_at          DateTime?      @default(now()) @db.Timestamp(6)
  users               users          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([razorpay_order_id], map: "idx_razorpay_order_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model poultry_eggs {
  egg_id           Int           @id @default(autoincrement())
  user_id          Int
  flock_id         Int
  date_collected   DateTime      @db.Date
  small_eggs       Int           @default(0)
  medium_eggs      Int           @default(0)
  large_eggs       Int           @default(0)
  extra_large_eggs Int           @default(0)
  total_eggs       Int           @default(0)
  broken_eggs      Int           @default(0)
  date_logged      DateTime?     @default(now()) @db.Timestamp(6)
  poultry_flock    poultry_flock @relation(fields: [flock_id], references: [flock_id], onDelete: Cascade, onUpdate: NoAction)
  users            users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([date_collected], map: "idx_poultry_eggs_date_collected")
  @@index([flock_id], map: "idx_poultry_eggs_flock_id")
  @@index([user_id], map: "idx_poultry_eggs_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model poultry_feeds {
  feed_id       Int           @id @default(autoincrement())
  user_id       Int
  flock_id      Int
  feed_given    String        @db.VarChar(100)
  amount_given  Decimal       @db.Decimal(8, 2)
  units         String        @db.VarChar(50)
  feed_date     DateTime      @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  poultry_flock poultry_flock @relation(fields: [flock_id], references: [flock_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_poultry_feeds_flock")
  users         users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_poultry_feeds_user")

  @@index([feed_date], map: "idx_poultry_feeds_feed_date")
  @@index([flock_id], map: "idx_poultry_feeds_flock_id")
  @@index([user_id], map: "idx_poultry_feeds_user_id")
}

model poultry_flock {
  flock_id       Int              @id @default(autoincrement())
  user_id        Int
  flock_name     String
  flock_type     String
  quantity       Int
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  breed          String?          @db.VarChar(100)
  source         String?          @db.VarChar(255)
  housing_type   String?          @db.VarChar(100)
  notes          String?
  poultry_eggs   poultry_eggs[]
  poultry_feeds  poultry_feeds[]
  users          users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  poultry_health poultry_health[]
}

model poultry_health {
  poultry_health_id Int           @id @default(autoincrement())
  user_id           Int
  flock_id          Int
  veterinary_name   String?       @db.VarChar(255)
  total_birds       Int
  birds_vaccinated  Int
  vaccines_given    String[]
  symptoms          String[]
  medicine_approved String[]
  remarks           String?
  next_appointment  DateTime?     @db.Date
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  poultry_flock     poultry_flock @relation(fields: [flock_id], references: [flock_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_flock")
  users             users         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([flock_id], map: "idx_poultry_health_flock_id")
  @@index([user_id], map: "idx_poultry_health_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sales {
  sales_id        Int       @id @default(autoincrement())
  user_id         Int
  sales_date      DateTime  @db.Date
  occupation      String?   @db.VarChar(100)
  items_sold      String[]
  quantities_sold Int[]
  quantity_unit   String?   @db.VarChar(50)
  invoice_created Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  sales_name      String?   @db.VarChar(255)
  prices_per_unit Decimal[] @default([]) @db.Decimal(10, 2)
  invoices        invoices?
  users           users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([sales_name], map: "idx_sales_sales_name")
  @@index([user_id], map: "idx_sales_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tasks {
  task_id     Int       @id @default(autoincrement())
  user_id     Int
  project     String    @db.VarChar(100)
  task        String?   @db.VarChar(255)
  status      String?   @db.VarChar(50)
  description String?
  priority    String?   @db.VarChar(10)
  deadline    DateTime? @db.Date
  created_on  DateTime? @default(now()) @db.Timestamp(6)
  users       users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  user_id                 Int              @id @default(autoincrement())
  first_name              String           @db.VarChar(50)
  last_name               String           @db.VarChar(50)
  email                   String           @unique @db.VarChar(100)
  phone_number            String           @unique @db.VarChar(15)
  business_name           String?          @db.VarChar(100)
  date_of_birth           DateTime?        @db.Date
  password                String           @db.VarChar(255)
  created_at              DateTime?        @default(now()) @db.Timestamp(6)
  language                String?          @default("English") @db.VarChar(50)
  time_format             String?          @default("24-hour") @db.VarChar(10)
  type                    String?          @db.VarChar(50)
  sub_type                String[]
  temperature_scale       String?          @default("Celsius") @db.VarChar(15)
  address_line_1          String?          @db.VarChar(255)
  address_line_2          String?          @db.VarChar(255)
  city                    String?          @db.VarChar(100)
  state                   String?          @db.VarChar(100)
  postal_code             String?          @db.VarChar(20)
  darkMode                Boolean          @default(false)
  widgets                 String[]         @default([])
  plan                    user_plan_type   @default(FREE)
  subscription_expires_at DateTime?        @db.Timestamp(6)
  apiculture              apiculture[]
  cattle_milk             cattle_milk[]
  cattle_rearing          cattle_rearing[]
  companies               companies[]
  contacts                contacts[]
  deals                   deals[]
  expenses                expenses[]
  inventory               inventory[]
  invoices                invoices[]
  labours                 labours[]
  login_history           login_history[]
  password_resets         password_resets?
  payments                payments[]
  poultry_eggs            poultry_eggs[]
  poultry_feeds           poultry_feeds[]
  poultry_flock           poultry_flock[]
  poultry_health          poultry_health[]
  sales                   sales[]
  tasks                   tasks[]
  warehouse               warehouse[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model warehouse {
  warehouse_id     Int         @id @default(autoincrement())
  user_id          Int?
  name             String      @db.VarChar(100)
  type             String      @db.VarChar(50)
  address_line_1   String?     @db.VarChar(255)
  address_line_2   String?     @db.VarChar(255)
  city             String?     @db.VarChar(100)
  state            String?     @db.VarChar(100)
  postal_code      String?     @db.VarChar(20)
  country          String?     @db.VarChar(100)
  contact_person   String?     @db.VarChar(100)
  phone            String?     @db.VarChar(20)
  storage_capacity Decimal?    @db.Decimal(10, 2)
  inventory        inventory[]
  users            users?      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

enum payment_status {
  PENDING
  SUCCESS
  FAILED
}

enum user_plan_type {
  FREE
  BASIC
  PRO
}
